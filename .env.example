# Email Configuration
# SMTP Host (e.g., smtp.gmail.com, smtp.sendgrid.net)
SMTP_HOST=smtp.gmail.com

# SMTP Port (typically 587 for TLS, 465 for SSL)
SMTP_PORT=587

# Use secure connection (true for port 465, false for 587)
SMTP_SECURE=false

# SMTP Username/Email
SMTP_USER=your-email@gmail.com

# SMTP Password (use app password for Gmail)
SMTP_PASSWORD=your-app-password

# Restaurant email (where reservation requests are sent)
RESTAURANT_EMAIL=reservations@manuka.com
